# Copy to .env and fill in real values before running docker compose in anything but local dev.

# HMAC signing key for JWTs. Must be at least 32 bytes. Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes

# Base URL of the guest-facing web app that QR codes deep-link into (?qr=<token> is appended).
ORDER_BASE_URL=https://your-ordering-frontend.example.com
